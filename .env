# Copy this file to `.env` and adjust the values for your environment.
# Path where the DuckDB database file should be stored (created automatically if missing).
DUCKDB_PATH=data/pymasters.duckdb
# Local AI gateway (OpenAI-compatible)
LOCAL_AI_BASE_URL=http://192.168.1.10:1234
#LOCAL_AI_API_KEY=
LOCAL_AI_DEFAULT_MODEL=local-llm
