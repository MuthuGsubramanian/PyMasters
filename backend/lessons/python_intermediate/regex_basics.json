    {
      "type": "CodeStepper",
      "id": "code_intro",
      "steps": [
        {
          "line": "import re",
          "highlight": "re",
          "explanation": {
            "en": "Import Python's built-in regex module"
          }
        },
        {
          "line": "text = 'Order #1234 placed on 2025-03-27 for $49.99'",
          "highlight": "text",
          "explanation": {
            "en": "Sample text with numbers, dates, and prices"
          }
        },
        {
          "line": "numbers = re.findall(r'\\d+', text)",
          "highlight": "findall",
          "explanation": {
            "en": "findall returns ALL matches as a list. \\d+ = one or more digits"
          }
        },
        {
          "line": "print(numbers)",
          "highlight": "print",
          "explanation": {
            "en": "['1234', '2025', '03', '27', '49', '99']"
          }
        },
        {
          "line": "match = re.search(r'#(\\d+)', text)",
          "highlight": "search",
          "explanation": {
            "en": "search finds the FIRST match anywhere in the string"
          }
        },
        {
          "line": "print(f'Order number: {match.group(1)}')",
          "highlight": "group(1)",
          "explanation": {
            "en": "group(1) returns the first captured group (in parentheses)"
          }
        },
        {
          "line": "date_match = re.search(r'(\\d{4})-(\\d{2})-(\\d{2})', text)",
          "highlight": "\\d{4}",
          "explanation": {
            "en": "Match a date pattern: 4 digits - 2 digits - 2 digits"
          }
        },
        {
          "line": "print(f'Year: {date_match.group(1)}, Month: {date_match.group(2)}')",
          "highlight": "group",
          "explanation": {
            "en": "Each parenthesized group can be accessed separately"
          }
        },
        {
          "line": "emails = 'Contact alice@example.com or bob@gmail.com'",
          "highlight": "emails",
          "explanation": {
            "en": "Text containing email addresses"
          }
        },
        {
          "line": "pattern = r'[\\w.]+@[\\w.]+'",
          "highlight": "pattern",
          "explanation": {
            "en": "Email pattern: word chars + @ + word chars"
          }
        },
        {
          "line": "found = re.findall(pattern, emails)",
          "highlight": "findall",
          "explanation": {
            "en": "Find all email-like patterns"
          }
        },
        {
          "line": "print(found)",
          "highlight": "print",
          "explanation": {
            "en": "['alice@example.com', 'bob@gmail.com']"
          }
        },
        {
          "line": "result = re.match(r'\\d+', 'abc123')",
          "highlight": "match",
          "explanation": {
            "en": "match only checks the START of the string"
          }
        },
        {
          "line": "print(result)",
          "highlight": "print",
          "explanation": {
            "en": "None — because 'abc123' doesn't START with digits"
          }
        },
        {
          "line": "result2 = re.search(r'\\d+', 'abc123')",
          "highlight": "search",
          "explanation": {
            "en": "search finds digits ANYWHERE — returns Match object"
          }
        },
        {
          "line": "print(result2.group())",
          "highlight": "group()",
          "explanation": {
            "en": "'123' — found the digits after 'abc'"
          }
        }
      ]
    },
