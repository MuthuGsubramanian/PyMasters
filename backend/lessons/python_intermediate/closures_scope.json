  "practice_challenges": [
    {
      "instruction": {
        "en": "Create a closure make_accumulator(initial) that returns a function. Each call to the returned function adds the given value to a running total. Start with 100 and add 10, 20, 30.",
        "ta": "make_accumulator(initial) closure உருவாக்குங்கள். திருப்பப்படும் function ஒவ்வொரு அழைப்பிலும் running total-க்கு value சேர்க்கும். 100-ல் தொடங்கி 10, 20, 30 சேர்க்கவும்."
      },
      "starter_code": "def make_accumulator(initial):\n    total = initial\n    def add(value):\n        nonlocal total\n        total += value\n        return total\n    return add\n\nacc = make_accumulator(100)\nprint(acc(10))   # 110\nprint(acc(20))   # 130\nprint(acc(30))   # 160",
      "expected_output": "110\n130\n160",
      "hints": {
        "en": [
          "Use nonlocal total to modify the enclosing variable",
          "total += value accumulates the sum",
          "Each call to acc() adds to the running total",
          "The closure remembers total between calls"
        ],
        "ta": [
          "enclosing variable-ஐ மாற்ற nonlocal total பயன்படுத்துங்கள்",
          "total += value தொகையை குவிக்கும்",
          "ஒவ்வொரு acc() அழைப்பும் running total-க்கு சேர்க்கும்",
          "closure அழைப்புகளுக்கு இடையே total நினைவில் வைக்கும்"
        ]
      }
    }
