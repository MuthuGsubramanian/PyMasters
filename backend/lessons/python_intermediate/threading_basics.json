  "practice_challenges": [
    {
      "instruction": {
        "en": "Create 3 threads that each increment a shared counter 100000 times using a Lock. Verify the final count is exactly 300000 (no race condition).",
        "ta": "3 threads உருவாக்கி ஒவ்வொன்றும் Lock பயன்படுத்தி shared counter-ஐ 100000 முறை increment செய்யுங்கள். இறுதி எண்ணிக்கை சரியாக 300000 என சரிபார்க்கவும்."
      },
      "starter_code": "import threading\n\ncounter = 0\nlock = threading.Lock()\n\ndef increment(n):\n    global counter\n    for _ in range(n):\n        with lock:\n            counter += 1\n\nthreads = [threading.Thread(target=increment, args=(100000,)) for _ in range(3)]\nfor t in threads:\n    t.start()\nfor t in threads:\n    t.join()\n\nprint(f'Final counter: {counter}')",
      "expected_output": "Final counter: 300000",
      "hints": {
        "en": [
          "Use 'with lock:' to protect counter += 1",
          "Without the lock, you'd get less than 300000",
          "Create threads in a list for clean iteration",
          "start() all, then join() all"
        ],
        "ta": [
          "counter += 1 பாதுகாக்க 'with lock:' பயன்படுத்துங்கள்",
          "lock இல்லாமல், 300000-க்கும் குறைவாக கிடைக்கும்",
          "சுத்தமான iteration-க்கு threads-ஐ list-ல் உருவாக்குங்கள்",
          "அனைத்தையும் start(), பின் அனைத்தையும் join()"
        ]
      }
    }
  ],
