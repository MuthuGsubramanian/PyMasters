      "type": "CodeStepper",
      "id": "code_intro",
      "steps": [
        {
          "line": "import re",
          "highlight": "re",
          "explanation": {
            "en": "Import the regex module"
          }
        },
        {
          "line": "log = '2025-03-27 ERROR: Connection timeout at 192.168.1.1'",
          "highlight": "log",
          "explanation": {
            "en": "A sample log line with date, level, and IP"
          }
        },
        {
          "line": "pattern = r'(?P<date>\\d{4}-\\d{2}-\\d{2}) (?P<level>\\w+): (?P<msg>.+)'",
          "highlight": "?P<date>",
          "explanation": {
            "en": "Named groups label each captured part"
          }
        },
        {
          "line": "m = re.search(pattern, log)",
          "highlight": "search",
          "explanation": {
            "en": "Search for the pattern in the log"
          }
        },
        {
          "line": "print(m.group('date'))",
          "highlight": "'date'",
          "explanation": {
            "en": "Access by NAME instead of number — much clearer"
          }
        },
        {
          "line": "print(m.group('level'))",
          "highlight": "'level'",
          "explanation": {
            "en": "Get the log level: 'ERROR'"
          }
        },
        {
          "line": "print(m.groupdict())",
          "highlight": "groupdict",
          "explanation": {
            "en": "Get ALL named groups as a dictionary"
          }
        },
        {
          "line": "prices = 'Apple $3.99, Banana $1.50, Cherry $5.00'",
          "highlight": "prices",
          "explanation": {
            "en": "Text with prices to transform"
          }
        },
        {
          "line": "lookahead = re.findall(r'\\w+(?=\\s\\$)', prices)",
          "highlight": "(?=",
          "explanation": {
            "en": "LOOKAHEAD: find words followed by ' $' — but don't include ' $'"
          }
        },
        {
          "line": "print(lookahead)",
          "highlight": "print",
          "explanation": {
            "en": "['Apple', 'Banana', 'Cherry'] — only the fruit names"
          }
        },
        {
          "line": "lookbehind = re.findall(r'(?<=\\$)\\d+\\.\\d{2}', prices)",
          "highlight": "(?<=",
          "explanation": {
            "en": "LOOKBEHIND: find numbers preceded by $ — but don't include $"
          }
        },
        {
          "line": "print(lookbehind)",
          "highlight": "print",
          "explanation": {
            "en": "['3.99', '1.50', '5.00'] — just the amounts"
          }
        },
        {
          "line": "censored = re.sub(r'\\d{3}-\\d{4}', 'XXX-XXXX', 'Call 555-1234 or 800-5678')",
          "highlight": "re.sub",
          "explanation": {
            "en": "re.sub replaces ALL matches with the replacement string"
          }
        },
        {
          "line": "print(censored)",
          "highlight": "print",
          "explanation": {
            "en": "'Call XXX-XXXX or XXX-XXXX' — phone numbers censored!"
          }
        },
        {
          "line": "email_pat = re.compile(r'[\\w.]+@[\\w.]+')",
          "highlight": "re.compile",
          "explanation": {
            "en": "Compile pattern ONCE for reuse — faster for repeated use"
          }
        },
        {
          "line": "found = email_pat.findall('a@b.com and c@d.com')",
          "highlight": ".findall",
          "explanation": {
            "en": "Use the compiled pattern's methods directly"
          }
        },
        {
          "line": "print(found)",
          "highlight": "print",
          "explanation": {
            "en": "['a@b.com', 'c@d.com']"
          }
        }
      ]
    },
