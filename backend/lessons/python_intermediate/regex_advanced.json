  "practice_challenges": [
    {
      "instruction": {
        "en": "Use re.sub with a function to convert all prices like $XX.XX to euros by multiplying by 0.92. E.g., '$10.00' becomes 'EUR 9.20'.",
        "ta": "re.sub-ஐ function-உடன் பயன்படுத்தி $XX.XX போன்ற அனைத்து விலைகளையும் 0.92 பெருக்கி euros-ஆக மாற்றுங்கள்."
      },
      "starter_code": "import re\n\ndef to_euros(match):\n    usd = float(match.group(1))\n    eur = usd * 0.92\n    return f'EUR {eur:.2f}'\n\ntext = 'Laptop $999.99, Mouse $29.99, Keyboard $79.99'\nresult = re.sub(r'\\$(\\d+\\.\\d{2})', to_euros, text)\nprint(result)",
      "expected_output": "Laptop EUR 919.99, Mouse EUR 27.59, Keyboard EUR 73.59",
      "hints": {
        "en": [
          "re.sub can take a function as the replacement",
