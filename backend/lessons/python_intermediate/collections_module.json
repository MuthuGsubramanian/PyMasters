        {
          "line": "from collections import Counter, defaultdict, namedtuple, deque",
          "highlight": "collections",
          "explanation": {
            "en": "Import all four specialized containers"
          }
        },
        {
          "line": "votes = ['Alice', 'Bob', 'Alice', 'Charlie', 'Alice', 'Bob']",
          "highlight": "votes",
          "explanation": {
            "en": "A list of votes to count"
          }
        },
        {
          "line": "tally = Counter(votes)",
          "highlight": "Counter",
          "explanation": {
            "en": "Counter counts occurrences automatically"
          }
        },
        {
          "line": "print(tally)",
          "highlight": "print",
          "explanation": {
            "en": "Counter({'Alice': 3, 'Bob': 2, 'Charlie': 1})"
          }
        },
        {
          "line": "print(tally.most_common(2))",
          "highlight": "most_common",
          "explanation": {
            "en": "[('Alice', 3), ('Bob', 2)] — top 2 by count"
          }
        },
        {
          "line": "groups = defaultdict(list)",
          "highlight": "defaultdict(list)",
          "explanation": {
            "en": "defaultdict auto-creates a list for missing keys"
          }
        },
        {
          "line": "students = [('Math', 'Alice'), ('Science', 'Bob'), ('Math', 'Charlie')]",
          "highlight": "students",
          "explanation": {
            "en": "Student-subject pairs to group"
          }
        },
        {
          "line": "for subject, student in students:",
          "highlight": "for",
          "explanation": {
            "en": "Loop through each pair"
          }
        },
        {
          "line": "    groups[subject].append(student)",
          "highlight": ".append",
          "explanation": {
            "en": "No KeyError! defaultdict creates the list automatically"
          }
        },
        {
          "line": "print(dict(groups))",
          "highlight": "print",
          "explanation": {
            "en": "{'Math': ['Alice', 'Charlie'], 'Science': ['Bob']}"
          }
        },
        {
          "line": "Point = namedtuple('Point', ['x', 'y'])",
          "highlight": "namedtuple",
          "explanation": {
            "en": "Create a lightweight class with named fields"
          }
        },
        {
          "line": "p = Point(3, 4)",
          "highlight": "Point(3, 4)",
          "explanation": {
            "en": "Create a Point instance — immutable like a tuple"
          }
        },
        {
          "line": "print(f'x={p.x}, y={p.y}')",
          "highlight": "p.x",
          "explanation": {
            "en": "Access fields by name — much clearer than tuple[0]"
          }
        },
        {
          "line": "dq = deque([1, 2, 3], maxlen=5)",
          "highlight": "deque",
          "explanation": {
            "en": "deque — double-ended queue with optional max length"
          }
        },
        {
          "line": "dq.appendleft(0)",
          "highlight": "appendleft",
          "explanation": {
            "en": "O(1) append to the LEFT — lists are O(n) for this!"
          }
        },
        {
          "line": "dq.append(4)",
          "highlight": "append",
          "explanation": {
            "en": "O(1) append to the right"
          }
        },
        {
          "line": "print(list(dq))",
          "highlight": "print",
          "explanation": {
            "en": "[0, 1, 2, 3, 4]"
          }
        }
