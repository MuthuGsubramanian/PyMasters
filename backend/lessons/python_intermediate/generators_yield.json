  "practice_challenges": [
    {
      "instruction": {
        "en": "Create a generator function called even_numbers(limit) that yields even numbers from 0 up to (but not including) limit. Use it to print even numbers below 10.",
        "ta": "even_numbers(limit) என்ற generator function உருவாக்குங்கள், 0-லிருந்து limit வரை (உள்ளடக்காமல்) இரட்டை எண்களை yield செய்யும். 10-க்கு கீழ் இரட்டை எண்களை அச்சிட பயன்படுத்துங்கள்."
      },
      "starter_code": "def even_numbers(limit):\n    # yield even numbers from 0 to limit\n    pass\n\nfor num in even_numbers(10):\n    print(num)",
      "expected_output": "0\n2\n4\n6\n8",
      "hints": {
        "en": [
          "Start with n = 0",
          "Use while n < limit",
          "yield n, then n += 2",
          "Or: for n in range(0, limit, 2): yield n"
        ],
        "ta": [
          "n = 0 உடன் தொடங்குங்கள்",
          "while n < limit பயன்படுத்துங்கள்",
          "yield n, பின் n += 2",
          "அல்லது: for n in range(0, limit, 2): yield n"
        ]
      }
    }
  ],
