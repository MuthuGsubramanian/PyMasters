  "practice_challenges": [
    {
      "instruction": {
        "en": "Create 3 async functions that simulate downloading files (1s, 2s, 3s delays). Use asyncio.gather to run them concurrently. Verify total time is ~3s not 6s.",
        "ta": "3 async functions உருவாக்குங்கள் — files download simulate (1s, 2s, 3s delays). asyncio.gather பயன்படுத்தி ஒரே நேரத்தில் இயக்குங்கள். மொத்த நேரம் ~3s என சரிபார்க்கவும்."
      },
      "starter_code": "import asyncio\nimport time\n\nasync def download(name, seconds):\n    print(f'Downloading {name}...')\n    await asyncio.sleep(seconds)\n    print(f'{name} done!')\n    return name\n\nasync def main():\n    start = time.time()\n    results = await asyncio.gather(\n        download('file1.txt', 1),\n        download('file2.txt', 2),\n        download('file3.txt', 3)\n    )\n    print(f'All done in {time.time()-start:.1f}s: {results}')\n\nasyncio.run(main())",
      "expected_output": "Downloading file1.txt...\nDownloading file2.txt...\nDownloading file3.txt...\nfile1.txt done!\nfile2.txt done!\nfile3.txt done!\nAll done in 3.0s: ['file1.txt', 'file2.txt', 'file3.txt']",
      "hints": {
        "en": [
          "Use async def for coroutine functions",
          "Use await asyncio.sleep() for non-blocking delays",
          "asyncio.gather() runs coroutines concurrently",
          "Total time = max delay (3s), not sum (6s)"
        ],
        "ta": [
          "coroutine functions-க்கு async def பயன்படுத்துங்கள்",
          "non-blocking delays-க்கு await asyncio.sleep()",
          "asyncio.gather() coroutines-ஐ ஒரே நேரத்தில் இயக்கும்",
          "மொத்த நேரம் = max delay (3s), sum அல்ல (6s)"
        ]
      }
    }
  ],
