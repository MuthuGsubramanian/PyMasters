  "practice_challenges": [
    {
      "instruction": {
        "en": "Create an async generator that yields the squares of numbers 1-5 with a 0.5s delay between each. Consume it with 'async for' and print each square.",
        "ta": "1-5 எண்களின் squares-ஐ 0.5s delay-உடன் yield செய்யும் async generator உருவாக்குங்கள். 'async for' மூலம் consume செய்து ஒவ்வொரு square-ஐயும் அச்சிடுங்கள்."
      },
      "starter_code": "import asyncio\n\nasync def square_stream(n):\n    for i in range(1, n + 1):\n        await asyncio.sleep(0.5)\n        yield i ** 2\n\nasync def main():\n    async for square in square_stream(5):\n        print(f'Square: {square}')\n\nasyncio.run(main())",
      "expected_output": "Square: 1\nSquare: 4\nSquare: 9\nSquare: 16\nSquare: 25",
      "hints": {
        "en": [
          "async def + yield = async generator",
          "Use await asyncio.sleep() for delay",
          "Use 'async for' to iterate",
          "yield i ** 2 gives the square"
        ],
        "ta": [
          "async def + yield = async generator",
          "delay-க்கு await asyncio.sleep() பயன்படுத்துங்கள்",
          "iterate செய்ய 'async for' பயன்படுத்துங்கள்",
          "yield i ** 2 square-ஐ தரும்"
        ]
      }
    }
