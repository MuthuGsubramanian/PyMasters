      },
      "starter_code": "from multiprocessing import Pool\nimport math\n\ndef factorial(n):\n    result = math.factorial(n)\n    print(f'{n}! = {result}')\n    return result\n\nif __name__ == '__main__':\n    numbers = [10, 15, 20, 25]\n    with Pool(4) as pool:\n        results = pool.map(factorial, numbers)\n    print(f'Results: {results}')",
      "expected_output": "10! = 3628800\n15! = 1307674368000\n20! = 2432902008176640000\n25! = 15511210043330985984000000\nResults: [3628800, 1307674368000, 2432902008176640000, 15511210043330985984000000]",
