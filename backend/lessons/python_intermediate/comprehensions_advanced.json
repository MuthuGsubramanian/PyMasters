        {
          "line": "matrix = [[1, 2, 3], [4, 5, 6], [7, 8, 9]]",
          "highlight": "matrix",
          "explanation": {
            "en": "A 3x3 matrix (list of lists)"
          }
        },
        {
          "line": "flat = [num for row in matrix for num in row]",
          "highlight": "for row in matrix for num in row",
