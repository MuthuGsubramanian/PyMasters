  "practice_challenges": [
    {
      "instruction": {
        "en": "Create a @dataclass called Book with title (str), author (str), pages (int), and price (float). Add a __post_init__ that sets a 'reading_time' field (pages / 30 hours). Create two books and print them.",
        "ta": "title, author, pages, price உடன் Book @dataclass உருவாக்குங்கள். __post_init__-ல் 'reading_time' (pages / 30 hours) field அமையுங்கள்."
      },
      "starter_code": "from dataclasses import dataclass, field\n\n@dataclass\nclass Book:\n    title: str\n    author: str\n    pages: int\n    price: float\n    reading_time: float = field(init=False)\n\n    def __post_init__(self):\n        self.reading_time = round(self.pages / 30, 1)\n\nb1 = Book('Python Mastery', 'Vaathiyaar', 450, 29.99)\nb2 = Book('Short Stories', 'Author B', 90, 9.99)\nprint(b1)\nprint(f'{b2.title}: ~{b2.reading_time}h to read')",
      "expected_output": "Book(title='Python Mastery', author='Vaathiyaar', pages=450, price=29.99, reading_time=15.0)\nShort Stories: ~3.0h to read",
      "hints": {
        "en": [
          "Use field(init=False) for computed fields",
          "__post_init__ runs after __init__",
          "self.reading_time = round(self.pages / 30, 1)",
          "The repr is auto-generated showing all fields"
        ],
        "ta": [
          "கணக்கிடப்பட்ட fields-க்கு field(init=False) பயன்படுத்துங்கள்",
          "__post_init__ __init__-க்குப் பின் இயங்கும்",
          "self.reading_time = round(self.pages / 30, 1)",
          "repr தானாக உருவாக்கப்பட்டு அனைத்து fields காட்டும்"
        ]
      }
    }
