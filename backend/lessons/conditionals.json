  "practice_challenges": [
    {
      "instruction": {
        "en": "Write a grade checker. If score >= 90 print 'A', if score >= 80 print 'B', if score >= 70 print 'C', otherwise print 'F'. Set score = 85 and run it.",
        "ta": "\u0924\u0930\u0948 \u0938\u094b\u0924\u0928\u0948 \u0909\u0923\u094d\u0921\u093e\u0915\u094d\u0915\u0941\u0919\u094d\u0915\u0933\u094d. score >= 90 \u090e\u0928\u094d\u0928\u093e\u0932\u094d 'A', >= 80 \u090e\u0928\u094d\u0928\u093e\u0932\u094d 'B', >= 70 \u090e\u0928\u094d\u0928\u093e\u0932\u094d 'C', \u0907\u0932\u094d\u0932\u0948\u092f\u0947\u0932\u094d 'F'. score = 85 \u0910\u0915 \u0935\u0948\u0915\u094d\u0915\u0935\u0941\u092e\u094d."
      },
      "starter_code": "score = 85\n\n# Write your if/elif/else below\nif score >= 90:\n    print('')\nelif score >= 80:\n    print('')\nelif score >= 70:\n    print('')\nelse:\n    print('')",
      "expected_output": "B",
      "hints": {
        "en": [
          "score = 85 is already set for you at the top",
          "Use >= to check 'greater than or equal to'",
          "elif lets you check a second condition only if the first was False",
          "else catches everything that didn't match any if or elif"
        ],
        "ta": [
          "score = 85 \u0910\u0932\u094d\u0932\u0947\u0924\u0947\u092f\u0947 \u0920\u093e\u0915\u094d\u0915\u0932\u094d\u092a\u091f\u094d\u0921\u0941\u0933\u094d\u0933\u0924\u0941",
          ">= \u090e\u0928\u094d\u092a\u0924\u0941 '\u0915\u0941\u0926\u093f\u0924\u094d\u0924\u094b \u0905\u0932\u094d\u0932\u0924\u0941 \u0938\u092e\u092e\u093e\u0928\u092e\u093e\u0915' \u0910\u0928\u094d\u092a\u0924\u0948 \u0915\u0941\u0931\u093f\u0915\u094d\u0915\u093f\u0928\u094d\u0931\u0924\u0941",
          "elif \u0907\u0930\u0923\u094d\u0921\u093e\u092e\u0924\u0941 \u0928\u093f\u092a\u0902\u0927\u0928\u0948\u0915\u0933\u0948 \u0909\u0930\u0942 \u0938\u094b\u0924\u093f\u0915\u094d\u0915\u093f\u0928\u094d\u0931\u0924\u0941",
          "else \u090f\u0928\u094d\u0928 \u0928\u093f\u092a\u0902\u0927\u0928\u0948\u0915\u0933\u093f\u0932\u0941\u092e\u094d \u092a\u094a\u0930\u0941\u0928\u094d\u0924\u093e\u0924\u0935\u0948\u0915\u0933\u0948 \u092a\u093f\u0921\u093f\u0915\u094d\u0915\u0941\u092e\u094d"
        ]
      }
    }
  ],
  "quiz": [
    {
      "q": {
        "en": "What keyword do you use to check a second condition if the first is False?",
        "ta": "\u0924\u0932\u093e\u092e\u0948 False \u0906\u0928\u093e\u0932\u094d \u0907\u0930\u0923\u094d\u0921\u093e\u092e\u0924\u0941 \u0928\u093f\u092a\u0902\u0927\u0928\u0948 \u0938\u094b\u0924\u093f\u0915\u094d\u0915 \u090f\u0928\u094d\u0928 \u0935\u093e\u0930\u094d\u0924\u094d\u0924\u0948 \u0909\u092a\u092f\u094b\u0915\u093f\u092a\u094d\u092a\u0940\u0930\u094d?"
      },
      "options": {
        "en": ["else", "elif", "then", "and"],
        "ta": ["else", "elif", "then", "and"]
      },
      "correct": 1
    },
    {
      "q": {
        "en": "In Python, what does the `else` block execute?",
        "ta": "Python\u0932\u093f\u0932\u094d `else` \u0924\u094b\u0915\u0941\u0921\u093f \u090f\u092a\u094d\u092a\u094b\u0924\u0941 \u0907\u092f\u0919\u094d\u0915\u0941\u092e\u094d?"
      },
      "options": {
        "en": [
          "Always",
          "Only when the if condition is True",
          "When none of the if/elif conditions are True",
          "Never"
        ],
        "ta": [
          "\u090e\u092a\u094d\u092a\u094b\u0924\u0941\u092e\u094d",
          "if \u0928\u093f\u092a\u0902\u0927\u0928\u0948 True \u0906\u0928\u093e\u0932\u094d \u092e\u091f\u094d\u0921\u0941\u092e\u094d",
          "if/elif \u090e\u0928\u094d\u0928 \u0928\u093f\u092a\u0902\u0927\u0928\u0948\u092f\u0941\u092e\u094d True \u0906\u0915\u093e\u0935\u093f\u091f\u094d\u0921\u093e\u0932\u094d",
          "\u090e\u0928\u094d\u092a\u094b\u0924\u0941\u092e\u094d \u0907\u0932\u094d\u0932\u0948"
        ]
      },
      "correct": 2
    }
  ],
  "adaptation_points": []
}
