        { "line": "age = 25", "highlight": "age", "explanation": { "en": "Create a variable called age holding an integer", "ta": "age \u090e\u0928\u094d\u0928\u0941\u092e\u094d \u092e\u093e\u0932\u094d\u092e\u0941 \u0909\u0923\u094d\u0921\u093e\u0915\u094d\u0915\u0941\u0919\u094d\u0915\u0933\u094d" } },
        { "line": "pi = 3.14", "highlight": "pi", "explanation": { "en": "Create a variable called pi holding a float", "ta": "pi \u090e\u0928\u094d\u0928\u0941\u092e\u094d \u092e\u093e\u0932\u094d\u092e\u0941 \u0909\u0923\u094d\u0921\u093e\u0915\u094d\u0915\u0941\u0919\u094d\u0915\u0933\u094d" } },
        { "line": "print(f'Hello, {name}! Age: {age}, Pi: {pi}')", "highlight": "print", "explanation": { "en": "Use an f-string to display all three values", "ta": "f-string \u092e\u0942\u0932\u092e\u094d \u092e\u0942\u0928\u094d\u0930\u0941 \u092e\u0924\u093f\u092a\u094d\u092a\u0941\u0915\u0933\u0948\u092f\u0941\u092e\u094d \u0915\u093e\u091f\u094d\u0921\u0941" } }
