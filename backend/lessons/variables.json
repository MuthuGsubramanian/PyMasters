  "practice_challenges": [
    {
      "instruction": {
        "en": "Create three variables: your name as a string, your age as an integer, and your favourite number as a float. Then print them all using an f-string.",
        "ta": "\u0950\u0928\u094d\u0924\u0941 \u092a\u0947\u092f\u0930\u0948 string \u0906\u0915, \u0950\u0928\u094d\u0924\u0941 \u0935\u092f\u0924\u0948 integer \u0906\u0915, \u0950\u0928\u094d\u0924\u0941 \u092e\u0928\u092a\u094d\u092a\u093f\u0930\u093f\u092f \u090e\u0923\u094d\u0923\u0948 float \u0906\u0915\u0935\u0941\u092e\u094d \u0909\u0923\u094d\u0921\u093e\u0915\u094d\u0915\u0941\u0919\u094d\u0915\u0933\u094d. \u092a\u093f\u0928\u094d\u0928\u0930\u094d f-string \u0909\u092a\u092f\u094b\u0915\u093f\u0924\u094d\u0924\u0941 \u0905\u0928\u0948\u0924\u094d\u0924\u0948\u092f\u0941\u092e\u094d \u0905\u091a\u094d\u0938\u093f\u0921\u0941."
      },
      "starter_code": "# Create your variables below\nname = \nyour_age = \nfavourite_number = \n\n# Print them using an f-string\nprint(f'')",
      "expected_output": "Name: <your_name>, Age: <your_age>, Favourite Number: <your_number>",
      "hints": {
        "en": [
          "Strings go inside quotes: name = 'Alice'",
          "Integers are plain numbers: age = 20",
          "Floats have a decimal point: favourite_number = 7.5",
          "In an f-string, wrap variable names in {}: f'Hello, {name}'"
        ],
        "ta": [
          "\u0935\u093e\u0930\u094d\u0924\u094d\u0924\u0948\u0915\u0933\u0941\u0915\u094d\u0915\u0941 \u092e\u0947\u0932\u094d\u092e\u0924\u093f\u092a\u094d\u092a\u0941 \u0924\u0947\u0935\u0948: name = 'Alice'",
          "\u090e\u0923\u094d\u0923\u0941\u0915\u0933\u094d \u0928\u0947\u0930\u0921\u093f\u092f\u093e\u0915 \u0920\u094b\u0915\u094d\u0915\u0932\u0940\u0928\u094d\u0930\u094d\u0915\u0933\u094d: age = 20",
          "\u0924\u0936\u092e \u092a\u0941\u0933\u094d\u0933\u093f\u092f\u093f\u0932\u094d\u0932\u093e\u0924\u0941 \u0909\u0933\u094d\u0933\u0924\u0941 float: favourite_number = 7.5",
          "f-string\u0932\u093f\u0932\u094d, \u092e\u093e\u0932\u094d\u092e\u0941 \u092a\u0947\u092f\u0930\u0948 {} \u0909\u0933\u094d\u0933\u0947 \u0935\u0948\u0915\u094d\u0915\u0935\u0941\u092e\u094d: f'Hello, {name}'"
        ]
      }
    }
  ],
