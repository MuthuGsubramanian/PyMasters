  "practice_challenges": [
    {
      "instruction": {
        "en": "Write a `is_palindrome(s)` function and use `@pytest.mark.parametrize` to test it with at least 4 cases: 'racecar' (True), 'hello' (False), 'madam' (True), '' (True).",
        "ta": "`is_palindrome(s)` செயல்பாட்டை எழுதி, குறைந்தது 4 cases-உடன் `@pytest.mark.parametrize` பயன்படுத்தி சோதிக்கவும்."
      },
      "starter_code": "import pytest\n\ndef is_palindrome(s):\n    # Return True if s reads the same forwards and backwards\n    pass\n\n@pytest.mark.parametrize('word,expected', [\n    # Add your test cases here\n])\ndef test_is_palindrome(word, expected):\n    assert is_palindrome(word) == expected",
      "expected_output": "4 passed",
      "hints": {
        "en": [
          "A palindrome reads the same backwards: s == s[::-1]",
          "Empty string is a palindrome by convention",
          "Add tuples like ('racecar', True) to parametrize"
        ],
        "ta": [
          "palindrome பின்னால் இருந்து படிக்கவும் ஒன்றே: s == s[::-1]",
          "காலி string மரபுப்படி palindrome ஆகும்",
          "parametrize-க்கு ('racecar', True) போன்ற tuples சேர்க்கவும்"
        ]
      }
    }
