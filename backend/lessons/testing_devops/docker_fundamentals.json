  "quiz": [
    {
      "q": {
        "en": "What is the relationship between a Docker image and a container?",
        "ta": "Docker image மற்றும் container இடையே என்ன உறவு?"
      },
      "options": {
        "en": [
          "They are the same thing",
          "An image is a running container",
          "A container is a running instance of an image",
          "A container creates images"
        ],
        "ta": [
          "அவை ஒன்றுதான்",
          "Image என்பது இயங்கும் container",
          "Container என்பது image-ன் இயங்கும் instance",
          "Container images-ஐ உருவாக்கும்"
        ]
      },
      "correct": 2
    },
    {
      "q": {
        "en": "Why copy requirements.txt BEFORE copying the rest of the code?",
        "ta": "மீதமுள்ள code-ஐ copy செய்வதற்கு முன் requirements.txt-ஐ ஏன் copy செய்கிறோம்?"
