  "practice_challenges": [
    {
      "instruction": {
        "en": "Write a GitHub Actions YAML workflow that: triggers on push to main, runs on ubuntu-latest, checks out code, sets up Python 3.11, installs requirements, and runs pytest.",
        "ta": "ஒரு GitHub Actions YAML workflow எழுதுங்கள்: main-க்கு push-ல் trigger ஆகும், ubuntu-latest-ல் இயங்கும், code checkout செய்யும், Python 3.11 setup செய்யும், requirements install செய்யும், pytest இயக்கும்."
      },
      "starter_code": "# .github/workflows/ci.yml\nname: CI\n\non:\n  push:\n    branches: [main]\n\njobs:\n  test:\n    runs-on: # which OS?\n    steps:\n      - uses: # checkout action?\n      - uses: actions/setup-python@v5\n        with:\n          python-version: # which version?\n      - run: # install dependencies?\n      - run: # run tests?",
      "expected_output": "Valid GitHub Actions workflow YAML",
