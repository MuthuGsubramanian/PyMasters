  "practice_challenges": [
    {
      "instruction": {
        "en": "Write a function `fetch_user(user_id)` that calls `requests.get()`. Then write a test using `@patch` that mocks the API and asserts the function returns the correct username from the mocked response.",
        "ta": "`requests.get()` அழைக்கும் `fetch_user(user_id)` செயல்பாடு எழுதுங்கள். பிறகு `@patch` பயன்படுத்தி API-ஐ mock செய்து சரியான username திருப்பப்படுகிறதா என்று assert செய்யும் test எழுதுங்கள்."
      },
      "starter_code": "import requests\nfrom unittest.mock import patch\n\ndef fetch_user(user_id):\n    response = requests.get(f'https://api.example.com/users/{user_id}')\n    return response.json()['name']\n\n@patch('__main__.requests.get')\ndef test_fetch_user(mock_get):\n    # Configure mock to return {'name': 'Muthu'}\n    # Call fetch_user(1)\n    # Assert result == 'Muthu'\n    pass",
      "expected_output": "1 passed",
      "hints": {
        "en": [
          "Set mock_get.return_value.json.return_value = {'name': 'Muthu'}",
          "Call result = fetch_user(1)",
          "Assert result == 'Muthu'"
        ],
        "ta": [
          "mock_get.return_value.json.return_value = {'name': 'Muthu'} அமைக்கவும்",
          "result = fetch_user(1) அழைக்கவும்",
          "result == 'Muthu' என்று assert செய்யவும்"
        ]
      }
    }
