# PyMasters backend configuration — copy to `backend/.env` and fill in.
# Loaded via python-dotenv at startup (backend/main.py).

# ── Database ───────────────────────────────────────────────────────────────
# SQLite file path. Defaults to an absolute path to backend/pymasters.db.
DB_PATH=pymasters.db

# ── Auth ───────────────────────────────────────────────────────────────────
# REQUIRED in production. Used to sign JWTs (HS256). Generate a strong value:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# The app refuses to start in production if this is left at the insecure default.
JWT_SECRET=dev-insecure-secret-change-me
# Comma-separated allowlist of platform super-admin emails.
SUPER_ADMIN_EMAILS=muthu@pymasters.net,muthu.g.subramanian@gmail.com

# ── AI tutor (Vaathiyaar) — Ollama Cloud ───────────────────────────────────
# REQUIRED for any AI flow (classroom chat, playground, module generation).
# Without it, AI endpoints return errors but the rest of the app works.
# Get a key at https://ollama.com (Cloud). Connects to https://ollama.com.
OLLAMA_API_KEY=
OLLAMA_MODEL=qwen3.5

# ── App ────────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:5173

# ── Email notifications (optional) ─────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=
FROM_NAME=PyMasters
# Brevo fallback (optional)
SMTP_BACKUP_HOST=
SMTP_BACKUP_PORT=
SMTP_BACKUP_USER=
SMTP_BACKUP_PASS=

# ── WhatsApp notifications (optional, Twilio) ──────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
