# Stray temp-path writes (Windows paths with drive letters captured as filenames)
C:Users*

# SQLite WAL sidecars
*.db-wal
*.db-shm

# LinkedIn OAuth token cache (secrets)
pipeline/.linkedin_tokens.json

# YouTube OAuth token cache (secrets)
pipeline/.youtube_token.json

# Service account / credential keys — never commit
key.json
*-key.json
*-credentials.json
*service-account*.json
gcp-*.json

# Local production-data backups (machine-first storage) — never commit user data
backups/
*.db
